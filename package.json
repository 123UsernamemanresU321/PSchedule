{
  "name": "adaptive-ib-olympiad-study-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
  "dev": "NEXT_OUTPUT_MODE=dev next dev --webpack",
  "build": "NEXT_OUTPUT_MODE=build next build --webpack",
  "build:pages": "NEXT_OUTPUT_MODE=pages next build --webpack",
  "start": "NEXT_OUTPUT_MODE=build next start",
  "lint": "eslint .",
  "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
  "test": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs --test tests/*.test.ts",
  "test:e2e": "playwright test",
  "benchmark:replan": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/benchmark-replan.ts"
},
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
